# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/devqueue

# JWT
JWT_SECRET=your_super_secret_key_min_32_chars_long
JWT_EXPIRE=7d

# Email (Nodemailer / Resend)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USER=resend
EMAIL_PASS=re_your_api_key
EMAIL_FROM=noreply@devqueue.studio

# Admin seed (for first-time setup)
ADMIN_EMAIL=admin@devqueue.studio
ADMIN_PASSWORD=SuperSecureAdminPass123!

# Frontend URL
CLIENT_URL=http://localhost:5173
